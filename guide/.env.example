# 导购平台 API 密钥（复制为 .env，勿提交 Git）
KIE_API_KEY=
YUNTTS_API_KEY=
YUNTTS_BASE_URL=https://www.yuntts.com/api/v1
WAVESPEED_API_KEY=
WAVESPEED_BASE_URL=https://api.wavespeed.ai
SERVER_URL=http://127.0.0.1:8000
DIGITAL_HUMAN_TRAINING_PROVIDER=cenker
# 可选：脚本润色 / AI 全自动流水线（OpenAI 兼容）
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
# 可选：在渲染 API / 导出对话框暴露 hyperframes_template 流水线
# ENABLE_HF_TEMPLATE_PIPELINE=1

# 可选：指向外部 FireRed-OpenStoryline 目录，用于按需复制 BGM 音频
# OPENSTORYLINE_ROOT=/Users/wuzhu/Documents/AI 项目/FireRed-OpenStoryline