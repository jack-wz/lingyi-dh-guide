# 导购平台 API 密钥（复制为 .env，勿提交 Git）
KIE_API_KEY=
YUNTTS_API_KEY=
YUNTTS_BASE_URL=https://www.yuntts.com/api/v1
WAVESPEED_API_KEY=
WAVESPEED_BASE_URL=https://api.wavespeed.ai
